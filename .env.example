# ============================================
# n8n Stack Configuration
# ============================================

# Environment: development, production
ENVIRONMENT=development

# ============================================
# Container Configuration
# ============================================
CONTAINER_NAME_N8N=n8n
CONTAINER_NAME_POSTGRES=postgres_pgvector
CONTAINER_NAME_OLLAMA=ollama
CONTAINER_NAME_PORTAINER=portainer

# Restart Policy Options:
#   - no: Do not automatically restart (recommended for development)
#   - always: Always restart regardless of exit status (recommended for production)
#   - on-failure: Restart only if container exits with non-zero status
#   - unless-stopped: Always restart unless explicitly stopped
RESTART_POLICY=unless-stopped

# ============================================
# Network Configuration
# ============================================
# Use 'shared_network' to share network with other services (e.g., Loki, RabbitMQ)
# Set NETWORK_EXTERNAL=true if the network already exists
NETWORK_NAME=shared_network
NETWORK_EXTERNAL=true

# ============================================
# Volume Configuration
# ============================================
VOLUME_N8N=n8n-data
VOLUME_POSTGRES=./postgres_data
VOLUME_OLLAMA=ollama-data
VOLUME_PORTAINER=portainer-data

# ============================================
# n8n Configuration
# ============================================
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_LISTEN_ADDRESS=0.0.0.0
N8N_SECURE_COOKIE=false
N8N_RUNNERS_ENABLED=true
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
DB_SQLITE_POOL_SIZE=5

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_PORT=5434
POSTGRES_INTERNAL_PORT=5432
POSTGRES_DB=vectordb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_INITDB_ARGS=--encoding=UTF8 --lc-collate=C --lc-ctype=C

# ============================================
# Ollama Configuration
# ============================================
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0
# Optional: Uncomment to limit resources
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1

# ============================================
# Portainer Configuration
# ============================================
PORTAINER_PORT_HTTPS=9443
PORTAINER_PORT_HTTP=9000
PORTAINER_PORT_AGENT=8000

# ============================================
# Image Versions (Optional)
# ============================================
# Use specific versions for production, 'latest' for development
# Uncomment to override defaults
# N8N_IMAGE=n8nio/n8n:1.70.0
# POSTGRES_IMAGE=pgvector/pgvector:pg16
# OLLAMA_IMAGE=ollama/ollama:latest
# PORTAINER_IMAGE=portainer/portainer-ce:latest

# ============================================
# Healthcheck Configuration (Optional)
# ============================================
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=30s
